# =====================================================================
# ESystem Backend — example env file
# Copy this to .env.local and fill in real values. .env.local is
# gitignored. These placeholders are SAFE to commit.
# =====================================================================

# Supabase (https://supabase.com/dashboard → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY

# Admin email — gates /admin* routes. Must match the Google account you sign in with.
ADMIN_EMAIL=you@gmail.com

# Cron secret — used as Authorization: Bearer <value> in the daily Vercel Cron call.
# Generate a new one: openssl rand -hex 32
CRON_SECRET=replace-me-with-a-long-random-string

# Public site URL
# - http://localhost:3000 for local dev
# - https://esystem.masud.app for production
NEXT_PUBLIC_SITE_URL=http://localhost:3000
