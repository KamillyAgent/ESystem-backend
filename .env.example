# =====================================================================
# ESystem Backend — example env file
# Copy this to .env.local and fill in real values. .env.local is
# gitignored. These placeholders are SAFE to commit.
# =====================================================================

# Supabase (https://supabase.com/dashboard → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY

# Auth0 (from Vercel → Integrations → Auth0, or Auth0 dashboard → Applications)
# - Install Auth0 via Vercel Integrations for the easiest setup
# - AUTH0_DOMAIN: the tenant domain (e.g. "esystem.us.auth0.com")
# - AUTH0_CLIENT_ID + AUTH0_CLIENT_SECRET: from the Auth0 application
# - AUTH0_BASE_URL: the public URL of this app (e.g. "https://esystem.masud.app")
# - AUTH0_SECRET: random 32+ char string for cookie encryption. Generate: openssl rand -hex 32
AUTH0_DOMAIN=YOUR-TENANT.auth0.com
AUTH0_CLIENT_ID=YOUR-AUTH0-CLIENT-ID
AUTH0_CLIENT_SECRET=YOUR-AUTH0-CLIENT-SECRET
AUTH0_BASE_URL=http://localhost:3000
AUTH0_SECRET=replac.....n
# Admin email — gates /admin* routes. Must match the Auth0 user you sign in with.
ADMIN_EMAIL=you@gmail.com

# Cron secret — used as Authorization: Bearer *** in the daily Vercel Cron call.
# Generate a new one: openssl rand -hex 32
CRON_SECRET=replac.....n
# Public site URL
# - http://localhost:3000 for local dev
# - https://esystem.masud.app for production
NEXT_PUBLIC_SITE_URL=http://localhost:3000
